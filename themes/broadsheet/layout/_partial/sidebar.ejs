<%
const recentPosts = site.posts
  ? site.posts.sort('date', -1).limit((theme.sidebar && theme.sidebar.recent_posts_limit) || 5).toArray()
  : [];
const categories = site.categories ? site.categories.toArray().filter(category => category.length) : [];
const tags = site.tags ? site.tags.toArray().filter(tag => tag.length).slice(0, 8) : [];
%>

<aside class="news-reference-grid gap-6 border-t-2 border-black pt-6">

  <div class="order-1 hidden p-6 md:block">
    <p class="text-[0.72rem] font-bold uppercase tracking-[0.15em]">Recent Posts</p>
    <div class="mt-5 space-y-4">
      <% recentPosts.forEach(function(post) { %>
        <article class="border-b border-black/12 pb-4 last:border-b-0 last:pb-0">
          <p class="text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-black/62">
            <%= date(post.date, 'DD MMM YYYY') %>
          </p>
          <h3 class="mt-2 font-serif text-xl leading-tight hover:text-blue-700">
            <a href="<%= url_for(post.path) %>"><%= post.title %></a>
          </h3>
        </article>
      <% }) %>
    </div>
  </div>

  <div class="order-2 grid gap-6">
    <% if (categories.length) { %>
      <div class="p-6">
        <p class="text-[0.72rem] font-bold uppercase tracking-[0.15em]">Sections</p>
        <div class="mt-5 space-y-3">
          <% categories.forEach(function(category) { %>
            <a href="<%= url_for(category.path) %>" class="flex items-center justify-between border border-black px-4 py-3 text-sm uppercase tracking-[0.18em] hover:text-white hover:bg-black transition-colors">
              <span><%= category.name %></span>
              <span><%= category.length %></span>
            </a>
          <% }) %>
        </div>
      </div>
    <% } %>

    <% if (tags.length) { %>
      <div class="p-6">
        <p class="text-[0.72rem] font-bold uppercase tracking-[0.15em]">Tags</p>
        <div class="mt-5 flex flex-wrap gap-2">
          <% tags.forEach(function(tag) { %>
            <a
              href="<%= url_for(tag.path) %>"
              class="border border-black px-3 py-2 text-[0.68rem] font-semibold uppercase tracking-[0.22em] hover:text-white hover:bg-black transition-colors"
            ><%= tag.name %></a>
          <% }) %>
        </div>
      </div>
    <% } %>
  </div>

  <div class="order-3 hidden gap-6 py-6 xl:grid">
    <div class="bg-black p-6 text-paper">
      <p class="text-[0.72rem] font-bold uppercase tracking-[0.15em] text-paper/80"><%= theme.author_card.kicker %></p>
      <h2 class="font-serif text-3xl leading-tight"><%= theme.author_card.title %></h2>
      <p class="mt-4 text-sm leading-7 text-paper/85">
        <%= theme.author_card.description %>
      </p>
      <% if (theme.author_card.link && theme.author_card.link_label) { %>
        <a
          href="<%= url_for(theme.author_card.link) %>"
          class="mt-6 inline-flex border border-white px-4 py-2 text-xs font-semibold uppercase tracking-[0.28em] hover:text-black hover:bg-white transition-colors"
        ><%= theme.author_card.link_label %></a>
      <% } %>
    </div>

    <div class="hidden p-6 md:block border-y border-black/50">
      <p class="text-[0.72rem] font-bold uppercase tracking-[0.15em]">Editorial Note</p>
      <h2 class="mt-3 font-serif text-2xl leading-tight"><%= theme.sidebar.note_title %></h2>
      <p class="mt-4 text-sm leading-7">
        <%= theme.sidebar.note_body %>
      </p>
    </div>
  </div>
</aside>
